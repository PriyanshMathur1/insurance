generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum UserRole {
  USER
  ADVISOR
  ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum InsuranceType {
  HEALTH
  TERM
  MIXED
  CLAIMS
  GENERAL
}

enum ChatIntent {
  HEALTH_ADVICE
  TERM_ADVICE
  CLAIMS
  PRODUCT_COMPARISON
  CONCEPT_EXPLANATION
  PROFILE_RECOMMENDATION
  GENERAL_EDUCATION
}

enum HandoffStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  role         UserRole         @default(USER)
  chats        Chat[]
  profile      CustomerProfile?
  messages     Message[]
  handoffs     HumanHandoff[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Chat {
  id                String            @id @default(cuid())
  userId            String
  title             String
  detectedIntent    ChatIntent        @default(GENERAL_EDUCATION)
  insuranceCategory InsuranceType     @default(GENERAL)
  extractedProfile  Json              @default("{}")
  complianceStatus  String            @default("pending")
  handoffStatus     HandoffStatus?
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          Message[]
  recommendations   Recommendation[]
  complianceChecks  ComplianceCheck[]
  humanHandoffs     HumanHandoff[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, updatedAt])
  @@index([insuranceCategory])
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  userId    String?
  role      MessageRole
  content   String
  citations Json        @default("[]")
  metadata  Json        @default("{}")
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())

  @@index([chatId, createdAt])
}

model CustomerProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  city          String?
  age           Int?
  profileData   Json           @default("{}")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthProfile HealthProfile?
  termProfile   TermProfile?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model HealthProfile {
  id                    String          @id @default(cuid())
  customerProfileId     String          @unique
  whoNeedsCover         String[]
  familyMemberAges      Json            @default("{}")
  existingPersonalCover Int?
  existingEmployerCover Int?
  preExistingDiseases   String[]
  budgetPerYear         Int?
  preference            String?
  customerProfile       CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model TermProfile {
  id                    String          @id @default(cuid())
  customerProfileId     String          @unique
  annualIncome          Int?
  dependents            Int?
  outstandingLoans      Int?
  existingLifeCover     Int?
  liquidAssets          Int?
  childrenEducationGoal Int?
  tobaccoStatus         String?
  desiredRetirementAge  Int?
  customerProfile       CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model Insurer {
  id             String          @id @default(cuid())
  name           String          @unique
  aliases        String[]
  insuranceTypes InsuranceType[]
  metadata       Json            @default("{}")
  healthProducts HealthProduct[]
  termProducts   TermProduct[]
  documents      SourceDocument[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model HealthProduct {
  id                              String   @id @default(cuid())
  insurerId                       String?
  insurerName                     String
  productName                     String
  sumInsuredOptions               String[]
  entryAge                        String?
  renewability                    String?
  initialWaitingPeriod            String?
  preExistingDiseaseWaitingPeriod String?
  specificDiseaseWaitingPeriod    String?
  roomRentLimit                   String?
  icuLimit                        String?
  coPay                           String?
  deductible                      String?
  restorationBenefit              String?
  noClaimBonus                    String?
  majorExclusions                 String[]
  claimProcess                    String?
  sourceDocument                  String?
  metadata                        Json     @default("{}")
  insurer                         Insurer? @relation(fields: [insurerId], references: [id], onDelete: SetNull)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@index([insurerName])
  @@index([productName])
}

model TermProduct {
  id                     String   @id @default(cuid())
  insurerId              String?
  insurerName            String
  productName            String
  entryAge               String?
  maxMaturityAge         String?
  policyTerm             String?
  sumAssuredRange        String?
  premiumPaymentOptions  String[]
  payoutOptions          String[]
  deathBenefit           String?
  terminalIllnessBenefit String?
  accidentalDeathRider   String?
  criticalIllnessRider   String?
  waiverOfPremiumRider   String?
  suicideClause          String?
  claimProcess           String?
  sourceDocument         String?
  metadata               Json     @default("{}")
  insurer                Insurer? @relation(fields: [insurerId], references: [id], onDelete: SetNull)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([insurerName])
  @@index([productName])
}

model SourceDocument {
  id            String          @id @default(cuid())
  insurerId     String?
  title         String
  filename      String
  sourceType    String
  insurerName   String?
  productName   String?
  insuranceType InsuranceType
  documentType  String
  content       String
  checksum      String
  lastUpdatedAt DateTime?
  metadata      Json            @default("{}")
  insurer       Insurer?         @relation(fields: [insurerId], references: [id], onDelete: SetNull)
  chunks        DocumentChunk[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([filename, checksum])
  @@index([insuranceType, documentType])
}

model DocumentChunk {
  id               String                   @id @default(cuid())
  sourceDocumentId String
  chunkIndex       Int
  content          String
  embedding        Unsupported("vector(1536)")?
  metadata         Json                     @default("{}")
  sourceDocument   SourceDocument           @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  createdAt        DateTime                 @default(now())

  @@unique([sourceDocumentId, chunkIndex])
}

model Recommendation {
  id               String        @id @default(cuid())
  chatId           String
  insuranceType    InsuranceType
  recommendedCover String?
  reasoning        String
  riskFlags        String[]
  productMatches   Json          @default("[]")
  sourceCitations  Json          @default("[]")
  metadata         Json          @default("{}")
  chat             Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
}

model ComplianceCheck {
  id           String   @id @default(cuid())
  chatId       String?
  responseText String
  passed       Boolean
  issues       String[]
  revisedText  String?
  metadata     Json     @default("{}")
  chat         Chat?     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model HumanHandoff {
  id                  String        @id @default(cuid())
  userId              String
  chatId              String
  insuranceType       InsuranceType
  userProfileSummary  String
  conversationSummary String
  recommendedCover    String?
  productsDiscussed   Json          @default("[]")
  riskFlags           String[]
  reason              String
  status              HandoffStatus @default(OPEN)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat                Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, createdAt])
}

model IngestionLog {
  id              String   @id @default(cuid())
  status          String
  dataRoot        String
  filesProcessed  Int      @default(0)
  productsLoaded  Int      @default(0)
  documentsLoaded Int      @default(0)
  chunksCreated   Int      @default(0)
  errors          Json     @default("[]")
  createdAt       DateTime @default(now())
}
